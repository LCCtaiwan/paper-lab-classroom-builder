{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "paper-lab-pilot",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-05-22",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "paper-lab-db",
      "migrations_dir": "drizzle"
    }
  ],
  "r2_buckets": [
    {
      "binding": "FILES"
    }
  ]
}
